@page "/send-request"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text.Json
@using System.IO
@inject IHttpClientFactory HttpClientFactory

<PageTitle>メッセージ送信</PageTitle>

<h1 class="mb-4">💬 Chatbot にメッセージを送信</h1>

<div class="card mb-4">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-semibold">メッセージ</label>
            <textarea class="form-control" rows="4" @bind="_message"
                      placeholder="メッセージを入力してください。例: こんにちは！ / attack!! / sexual content"></textarea>
        </div>

        <button class="btn btn-primary" @onclick="SendMessage"
                disabled="@(_sending || string.IsNullOrWhiteSpace(_message))">
            @if (_sending)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            送信
        </button>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">
        <strong>エラー:</strong> @_error
    </div>
}

@if (_streamingText is not null || _evaluationText is not null || _statusText is not null)
{
    <div class="card border-success mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <strong>@(_sending ? "⏳ 応答受信中..." : "✅ レスポンス")</strong>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <h6 class="text-muted">送信メッセージ</h6>
                <div class="p-2 bg-light rounded">
                    <code>@_lastSentMessage</code>
                </div>
            </div>
            @if (_streamingText is not null)
            {
                <div class="mb-3">
                    <h6 class="text-muted">Chatbot の返答</h6>
                    <div class="p-3 bg-success bg-opacity-10 rounded">
                        <p class="mb-0" style="white-space: pre-wrap;">@_streamingText</p>
                        @if (_sending && _evaluationText is null)
                        {
                            <span class="blinking-cursor">▌</span>
                        }
                    </div>
                </div>
            }
            @if (_statusText is not null)
            {
                <div class="mb-3">
                    <div class="text-muted fst-italic">
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        @_statusText
                    </div>
                </div>
            }
            @if (_evaluationText is not null)
            {
                <div class="mb-3">
                    <h6 class="text-muted">評価結果</h6>
                    <div class="p-3 bg-warning bg-opacity-10 rounded border border-warning">
                        <p class="mb-0" style="white-space: pre-wrap;">@_evaluationText</p>
                    </div>
                </div>
            }
        </div>
    </div>
}

@if (_history.Any())
{
    <h5 class="mt-4 mb-3">📜 送信履歴</h5>
    <div class="list-group">
        @foreach (var item in _history)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-secondary">@item.Time.ToString("HH:mm:ss")</span>
                    @if (item.HasError)
                    {
                        <span class="badge bg-danger">エラー</span>
                    }
                    else if (item.IsFlagged)
                    {
                        <span class="badge bg-warning text-dark">⚠ フラグ付き</span>
                    }
                    else
                    {
                        <span class="badge bg-success">✓ 正常</span>
                    }
                </div>
                <div class="small mb-1">
                    <span class="fw-semibold">送信:</span>
                    <span class="text-muted">@item.Message</span>
                </div>
                <div class="small">
                    <span class="fw-semibold">返答:</span>
                    <span class="text-muted" style="white-space: pre-wrap;">@item.Reply</span>
                </div>
            </div>
        }
    </div>
}

<style>
    .blinking-cursor {
        animation: blink 1s step-end infinite;
        color: #198754;
        font-weight: bold;
    }
    @@keyframes blink {
        50% { opacity: 0; }
    }
</style>

@code {
    private string _message = "";
    private bool _sending = false;
    private string? _error;
    private string? _streamingText;
    private string? _evaluationText;
    private string? _statusText;
    private string? _lastSentMessage;
    private List<HistoryItem> _history = new();

    private async Task SendMessage()
    {
        _sending = true;
        _error = null;
        _streamingText = "";
        _evaluationText = null;
        _statusText = null;
        _lastSentMessage = _message;

        try
        {
            var http = HttpClientFactory.CreateClient("chatbot");

            // A2A プロトコルに従った JSON-RPC リクエストを構築
            var request = new
            {
                jsonrpc = "2.0",
                id = Guid.NewGuid().ToString(),
                method = "message/send",
                @params = new
                {
                    message = new
                    {
                        kind = "message",
                        role = "user",
                        messageId = Guid.NewGuid().ToString(),
                        parts = new[]
                        {
                            new { kind = "text", text = _message }
                        }
                    }
                }
            };

            var httpRequest = new HttpRequestMessage(HttpMethod.Post, "/agent/stream")
            {
                Content = JsonContent.Create(request)
            };
            using var httpResponse = await http.SendAsync(httpRequest, HttpCompletionOption.ResponseHeadersRead);

            if (!httpResponse.IsSuccessStatusCode)
            {
                var errorBody = await httpResponse.Content.ReadAsStringAsync();
                _error = $"HTTP エラー ({(int)httpResponse.StatusCode}): {errorBody}";
                _history.Insert(0, new HistoryItem(_lastSentMessage, _error, DateTime.Now, true, false));
                return;
            }

            // SSE ストリームを読み取る
            using var stream = await httpResponse.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            string? currentEvent = null;

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line is null) break;

                if (line.StartsWith("event: "))
                {
                    currentEvent = line["event: ".Length..];
                }
                else if (line.StartsWith("data: ") && currentEvent is not null)
                {
                    var data = line["data: ".Length..];
                    await ProcessSseEvent(currentEvent, data);
                    currentEvent = null;
                }
            }

            // 履歴に追加
            var reply = _streamingText ?? "";
            if (_evaluationText is not null) reply += "\n\n" + _evaluationText;
            var isFlagged = reply.Contains("問題のあるコンテンツ") || reply.Contains("flagged");
            _history.Insert(0, new HistoryItem(_lastSentMessage, reply, DateTime.Now, false, isFlagged));
            if (_history.Count > 10) _history.RemoveAt(_history.Count - 1);

            _message = "";
        }
        catch (Exception ex)
        {
            _error = $"送信に失敗しました: {ex.Message}";
            _history.Insert(0, new HistoryItem(_lastSentMessage, _error, DateTime.Now, true, false));
        }
        finally
        {
            _sending = false;
            _statusText = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ProcessSseEvent(string eventType, string data)
    {
        switch (eventType)
        {
            case "token":
                using (var doc = JsonDocument.Parse(data))
                {
                    var text = doc.RootElement.GetProperty("text").GetString() ?? "";
                    _streamingText += text;
                }
                await InvokeAsync(StateHasChanged);
                break;

            case "status":
                using (var doc = JsonDocument.Parse(data))
                {
                    _statusText = doc.RootElement.GetProperty("text").GetString();
                }
                await InvokeAsync(StateHasChanged);
                break;

            case "evaluation":
                _statusText = null;
                using (var doc = JsonDocument.Parse(data))
                {
                    _evaluationText = doc.RootElement.GetProperty("text").GetString();
                }
                await InvokeAsync(StateHasChanged);
                break;

            case "done":
                _statusText = null;
                await InvokeAsync(StateHasChanged);
                break;

            case "error":
                using (var doc = JsonDocument.Parse(data))
                {
                    _error = doc.RootElement.GetProperty("text").GetString();
                }
                await InvokeAsync(StateHasChanged);
                break;
        }
    }

    private record HistoryItem(string Message, string Reply, DateTime Time, bool HasError, bool IsFlagged);
}